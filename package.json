{
  "private": true,
  "workspaces": [
    "lib",
    "website"
  ],
  "scripts": {
    "changeset": "changeset",
    "version": "changeset version",
    "build:package": "yarn workspace react-svg-worldmap build",
    "build:website": "yarn workspace website build",
    "build": "yarn build:package && yarn build:website",
    "generate:readme": "yarn workspace react-svg-worldmap generate:readme",
    "start:website": "yarn workspace website start",
    "lint": "eslint --cache \"**/*.{js,jsx,ts,tsx}\"",
    "format": "prettier --write .",
    "format-check": "prettier --list-different .",
    "typecheck": "yarn workspace website typecheck",
    "spellcheck": "cspell \"**\" --no-progress",
    "test": "yarn workspace react-svg-worldmap test",
    "test:coverage": "yarn workspace react-svg-worldmap test:coverage",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@types/react": "^18.0.15",
    "@typescript-eslint/eslint-plugin": "^5.30.7",
    "@typescript-eslint/parser": "^5.30.7",
    "cspell": "^6.4.0",
    "eslint": "^8.20.0",
    "eslint-config-jc": "^2.3.2",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-jsx-a11y": "^6.6.0",
    "eslint-plugin-react": "^7.30.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "husky": "^8.0.1",
    "lint-staged": "^13.0.3",
    "prettier": "^3.0.0",
    "prettier-config-jc": "^2.3.0",
    "tsconfig-jc": "^2.3.0",
    "typescript": "^4.7.4"
  },
  "version": "2.0.0"
}
