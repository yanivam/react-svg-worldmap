{
  "extends": "../node_modules/tsconfig-jc/tsconfig.json",
  "include": ["src", "tsup.config.ts"],
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "jsx": "react",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "esnext",
    "rootDir": ".",
    "outDir": "./dist",
    "importHelpers": true,
    "noEmitHelpers": true
  }
}
